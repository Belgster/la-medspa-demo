---
/*
 * §8 — Financing + Instagram split
 *
 * Two halves side-by-side on desktop, stacked on mobile.
 * Left: Financing (Beautifi) on dark brown — picks up the footer's palette,
 * gives the practical block some gravitas.
 * Right: Instagram preview — 4-tile grid of asset-pack shots with
 * @laseradvantage handle and a CTA to follow.
 */
import { Picture } from 'astro:assets';
import tile1 from '../assets/157.jpg';
import tile2 from '../assets/70.jpg';
import tile3 from '../assets/40.jpg';
import tile4 from '../assets/80.jpg';

const BEAUTIFI_URL = 'https://app.beautifi.com/application/laser-advantage-medspa';
const IG_URL = 'https://www.instagram.com/laseradvantage/';

const tiles = [
  { src: tile1, alt: 'HydraFacial treatment in progress' },
  { src: tile2, alt: 'Facial treatment close-up' },
  { src: tile3, alt: 'Laser treatment with clinician and client in safety goggles' },
  { src: tile4, alt: 'Clinician portrait against dark panel' },
];
---
<section class="grid md:grid-cols-2">
  {/* Financing — dark brown */}
  <div class="bg-brown text-cream px-card md:px-section-s py-section-s lg:py-section-l flex flex-col justify-center">
    <div class="max-w-[440px]">
      <div class="font-display font-medium text-[11px] uppercase tracking-[0.14em] text-cream/60 mb-comfort">
        Financing · Beautifi
      </div>
      <h2 class="font-display font-medium uppercase text-cream text-[clamp(32px,4.5vw,48px)] tracking-[-0.01em] leading-[1.05] mb-card">
        Pay Over Time
      </h2>
      <p class="font-body font-light text-[16px] leading-[1.75] text-cream/80 mb-stack">
        Beautifi offers monthly payment plans built for medical aesthetics.
        Apply in under five minutes; most decisions come back instantly,
        with flexible terms that keep the work on your timeline.
      </p>
      <ul class="space-y-[10px] mb-stack">
        {[
          'Instant pre-approval · soft credit pull',
          'Terms from 6 to 60 months',
          '0% promotional financing for qualified plans',
        ].map((item) => (
          <li class="flex items-start gap-[10px] font-body font-light text-[14px] leading-[1.6] text-cream/80">
            <span aria-hidden="true" class="text-gold text-[13px] mt-[3px]">+</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
      <a
        href={BEAUTIFI_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-[10px] font-display font-medium uppercase tracking-[0.12em] rounded-pill border border-cream text-cream bg-transparent px-[28px] py-[14px] text-[13px] no-underline transition-all duration-la-base ease-la-ease hover:bg-gold hover:text-ink hover:border-gold focus-visible:outline-none focus-visible:shadow-focus"
      >
        Apply with Beautifi <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>

  {/* Instagram — cream surface, photo grid */}
  <div class="bg-cream px-card md:px-section-s py-section-s lg:py-section-l flex flex-col justify-center">
    <div class="max-w-[440px] mb-stack">
      <div class="font-display font-medium text-[11px] uppercase tracking-[0.14em] text-charcoal-soft mb-comfort">
        @laseradvantage · Instagram
      </div>
      <h2 class="font-display font-medium uppercase text-ink text-[clamp(32px,4.5vw,48px)] tracking-[-0.01em] leading-[1.05] mb-card">
        See The Work
      </h2>
      <p class="font-body font-light text-[16px] leading-[1.75] text-charcoal mb-card">
        Daily detail from the clinic — before and afters, new services,
        the team between treatments.
      </p>
    </div>

    <div class="grid grid-cols-4 gap-[6px] mb-stack">
      {tiles.map((t) => (
        <a
          href={IG_URL}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Open LA Medspa on Instagram"
          class="relative block aspect-square overflow-hidden rounded-[4px] group"
        >
          <Picture
            src={t.src}
            formats={['avif', 'webp']}
            widths={[160, 240, 320, 480]}
            sizes="(min-width: 768px) 12vw, 25vw"
            alt={t.alt}
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover transition-all duration-la-base ease-la-ease group-hover:brightness-110"
          />
          <div aria-hidden="true" class="absolute inset-0 bg-brown/0 group-hover:bg-brown/10 transition-colors duration-la-base ease-la-ease"></div>
        </a>
      ))}
    </div>

    <a
      href={IG_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-[10px] font-display font-medium uppercase tracking-[0.12em] rounded-pill border border-brown text-brown bg-transparent px-[28px] py-[14px] text-[13px] no-underline transition-all duration-la-base ease-la-ease hover:bg-brown hover:text-cream focus-visible:outline-none focus-visible:shadow-focus w-fit"
    >
      Follow on Instagram <span aria-hidden="true">↗</span>
    </a>
  </div>
</section>
