---
/*
 * §7 — Testimonials + Team preview
 *
 * Testimonials: the live site publishes no reviews (confirmed across /,
 * /about-us/, /specials/, /testimonials/ → 404). Per the hard-limit rule
 * "no testimonials you can't source from the current site's actual Google
 * Reviews," the demo ships a styled 3-card layout preview with a "Coming
 * in Phase 3" overlay — same pattern as the §6 Before & After placeholder.
 * Phase 3 will wire real Google Reviews via their Business Profile API
 * or equivalent embed.
 *
 * Team preview: real names + credentials sourced from the live /about-us/
 * page. 10 team members — matches the "10 clinicians" stat in §2.
 * Initial-circle avatars since no headshots are in the asset pack
 * (flagged in the manifest and phase3-refinements notes).
 */

interface Person { name: string; initials: string; role: string; }

const team: Person[] = [
  { name: 'Jennifer Kapur',  initials: 'JK', role: 'RN · Managing Director' },
  { name: 'Dr. Cory Goldberg', initials: 'CG', role: 'MD · Plastic Surgeon' },
  { name: 'Sara Rocchetta',  initials: 'SR', role: 'NP · Aesthetic Specialist' },
  { name: 'Andrew Metcalfe', initials: 'AM', role: 'NP · Medical Aesthetics' },
  { name: 'Angie Glavota',   initials: 'AG', role: 'RN' },
  { name: 'Riley Guzzo',     initials: 'RG', role: 'Medical Esthetician' },
  { name: 'Jenna Battisti',  initials: 'JB', role: 'Medical Esthetician' },
  { name: 'Mariah Ruscio',   initials: 'MR', role: 'Medical Esthetician' },
  { name: 'Nikka Merena',    initials: 'NM', role: 'Medical Esthetician' },
  { name: 'Raea Caruso',     initials: 'RC', role: 'Clinic Manager' },
];
---
{/* Testimonials strip */}
<section class="max-w-[1400px] mx-auto px-card py-section-l">
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-comfort mb-stack">
    <div class="max-w-[560px]">
      <div class="font-display font-medium text-[11px] uppercase tracking-[0.14em] text-charcoal-soft mb-comfort">
        Words · Phase 3
      </div>
      <h2 class="font-display font-medium uppercase text-ink text-[clamp(32px,4.5vw,48px)] tracking-[-0.01em] leading-[1.05]">
        What Our<br />Clients Say
      </h2>
    </div>
    <p class="max-w-[420px] font-body font-light text-[15px] leading-[1.7] text-charcoal">
      Reviews are pulled from our Google Business profile when the full
      site ships — real names, real treatments, unedited.
    </p>
  </div>

  <div class="relative grid grid-cols-1 md:grid-cols-3 gap-comfort">
    {[0, 1, 2].map((i) => (
      <article
        aria-hidden="true"
        class="relative bg-cream border border-hairline rounded-card p-card flex flex-col gap-card"
      >
        {/* Stars — gold, static, visual placeholder */}
        <div class="flex gap-[4px]" aria-hidden="true">
          {[0,0,0,0,0].map(() => (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#F1AC32"><path d="M12 2l2.9 6.9L22 10l-5.5 4.8L18.2 22 12 18.3 5.8 22l1.7-7.2L2 10l7.1-1.1z"/></svg>
          ))}
        </div>
        <blockquote class="font-serif italic text-[18px] leading-[1.45] text-charcoal-soft">
          {i === 0 && '"Real review text will replace this quote — pulled from the live Google Business profile in Phase 3."'}
          {i === 1 && '"Client quotes are curated for consent and treatment accuracy before going live."'}
          {i === 2 && '"Review cards preview the layout — five-star pattern, treatment tag, first-name attribution."'}
        </blockquote>
        <div class="mt-auto flex items-center gap-[10px]">
          <div class="w-[36px] h-[36px] rounded-pill bg-beige border border-hairline"></div>
          <div>
            <div class="font-display font-medium text-[12px] uppercase tracking-[0.12em] text-charcoal-soft">
              Client Name
            </div>
            <div class="font-mono text-[10px] uppercase tracking-[0.14em] text-charcoal-soft">
              Treatment · TBD
            </div>
          </div>
        </div>
      </article>
    ))}

    {/* Coming-soon cartouche — consistent with §6 treatment */}
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <div class="bg-cream/95 backdrop-blur-sm border border-hairline rounded-card px-stack py-card text-center max-w-[420px] shadow-md">
        <div class="font-mono text-[10.5px] uppercase tracking-[0.18em] text-charcoal-soft mb-[8px]">
          Coming with Phase 3
        </div>
        <div class="font-display font-medium uppercase text-ink text-[clamp(18px,2.4vw,22px)] leading-[1.3]">
          Real Google Reviews,<br />Pulled Live
        </div>
      </div>
    </div>
  </div>
</section>

{/* Team preview — beige surface for emphasis */}
<section class="bg-beige">
  <div class="max-w-[1400px] mx-auto px-card py-section-l">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-comfort mb-stack">
      <div class="max-w-[560px]">
        <div class="font-display font-medium text-[11px] uppercase tracking-[0.14em] text-charcoal-soft mb-comfort">
          Ten specialists · One roof
        </div>
        <h2 class="font-display font-medium uppercase text-ink text-[clamp(32px,4.5vw,48px)] tracking-[-0.01em] leading-[1.05]">
          The Team
        </h2>
      </div>
      <p class="max-w-[420px] font-body font-light text-[15px] leading-[1.7] text-charcoal">
        Registered Nurses, a Nurse Practitioner duo, a board-certified
        plastic surgeon, and the medical estheticians who carry the plan
        between visits.
      </p>
    </div>

    <div class="overflow-x-auto pb-card la-team-scroll -mx-card px-card">
      <ul class="flex gap-comfort snap-x snap-mandatory w-max">
        {team.map((p) => (
          <li class="snap-start flex-shrink-0 w-[220px] bg-cream border border-hairline rounded-card p-card flex flex-col gap-base">
            <div class="w-[64px] h-[64px] rounded-pill bg-gold-wash border border-gold/30 flex items-center justify-center">
              <span class="font-display font-medium text-[22px] text-ink tracking-[0.05em]">
                {p.initials}
              </span>
            </div>
            <div class="mt-auto">
              <div class="font-display font-medium uppercase text-ink text-[15px] leading-[1.2]">
                {p.name}
              </div>
              <div class="font-mono text-[10.5px] uppercase tracking-[0.14em] text-charcoal-soft mt-[6px]">
                {p.role}
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  /* Quiet scrollbar on the team strip — visible enough to cue scrollability
     without being loud. */
  .la-team-scroll::-webkit-scrollbar { height: 6px; }
  .la-team-scroll::-webkit-scrollbar-track { background: transparent; }
  .la-team-scroll::-webkit-scrollbar-thumb {
    background: #D4C8B8;
    border-radius: 9999px;
  }
  .la-team-scroll { scrollbar-width: thin; scrollbar-color: #D4C8B8 transparent; }
</style>
