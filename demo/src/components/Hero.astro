---
import { getImage } from 'astro:assets';
import ButtonLink from './ui/ButtonLink.astro';
import heroDesktop from '../assets/hero-desktop.jpg';
import heroMobile from '../assets/hero-mobile.jpg';

const JANE_URL = 'https://laseradvantage.janeapp.com/';

const ALT = 'LA Medspa consultation — clinician reviewing treatment plan with client on tablet';

// Art-direction responsive hero: vertical composition on mobile
// (subject bottom-right), horizontal on tablet/desktop (subject right).
// WebP only — AVIF build cost isn't worth it for photographic hero content.
const mobileWidths  = [480, 640, 828, 1080, 1280];
const desktopWidths = [960, 1280, 1600, 1920, 2400];

const toSrcset = async (src: ImageMetadata, widths: number[]) => {
  const entries = await Promise.all(
    widths.map((w) => getImage({ src, format: 'webp', width: w })),
  );
  return entries.map((e, i) => `${e.src} ${widths[i]}w`).join(', ');
};

const [mobileWebp, desktopWebp, fallback] = await Promise.all([
  toSrcset(heroMobile,  mobileWidths),
  toSrcset(heroDesktop, desktopWidths),
  getImage({ src: heroDesktop, format: 'webp', width: 1600 }),
]);
---
<section class="relative min-h-screen min-h-[100svh] overflow-hidden bg-brown text-cream">
  <picture class="absolute inset-0 block">
    <source media="(min-width: 768px)" type="image/webp" srcset={desktopWebp} sizes="100vw" />
    <source media="(max-width: 767px)" type="image/webp" srcset={mobileWebp}  sizes="100vw" />
    <img
      src={fallback.src}
      alt={ALT}
      width={heroDesktop.width}
      height={heroDesktop.height}
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover object-center"
    />
  </picture>

  {/* Warm dark overlay — vertical on mobile (darker top band where copy lives,
      clearing toward the subject at the bottom), horizontal on desktop
      (darker-left, lighter-right). Scoped via <style> below. */}
  <div aria-hidden="true" class="absolute inset-0 hero-overlay"></div>

  <div class="relative z-10 min-h-screen min-h-[100svh] flex items-start md:items-center">
    <div class="max-w-[1400px] mx-auto w-full px-card pt-[80px] pb-section-s md:py-section-s lg:py-section-l md:pl-[8%]">
      <div class="max-w-[640px]">
        <div class="font-display font-medium text-[11px] uppercase tracking-[0.14em] text-cream/80 mb-comfort">
          Medical Aesthetics · Sault Ste. Marie
        </div>
        <h1 class="font-display font-medium uppercase text-cream text-[clamp(40px,6.5vw,72px)] leading-[1.05] tracking-[-0.015em] mb-card">
          Less Is More.<br />Simple Is Best.<br />Always Natural.
        </h1>
        <p class="font-body font-light text-[18px] leading-[1.7] text-cream/85 max-w-[480px] mb-stack">
          Medical-led aesthetics for the client who wants to look rested, not redone.
        </p>
        <div class="flex gap-[14px] flex-wrap">
          <ButtonLink href={JANE_URL} external variant="primary" size="lg">
            Book Consultation
          </ButtonLink>
          <ButtonLink href="#finder" variant="on-dark" size="lg">
            Find Your Treatment
          </ButtonLink>
        </div>
      </div>
    </div>
  </div>

  {/* Subtle scroll indicator — absolute bottom, out of the content flow */}
  <div
    aria-hidden="true"
    class="absolute left-1/2 -translate-x-1/2 bottom-[28px] text-cream/70 flex flex-col items-center gap-[10px] pointer-events-none"
  >
    <span class="font-display font-medium text-[10px] uppercase tracking-[0.22em]">Scroll</span>
    <span class="block w-px h-[28px] bg-current la-scroll-pulse"></span>
  </div>
</section>

<style>
  /* Mobile (default): vertical — darker top band over copy, clearing toward the subject at the bottom */
  .hero-overlay {
    background: linear-gradient(
      180deg,
      rgba(22, 17, 14, 0.72) 0%,
      rgba(22, 17, 14, 0.45) 38%,
      rgba(22, 17, 14, 0.18) 70%,
      rgba(22, 17, 14, 0.10) 100%
    );
  }
  /* Tablet+ (≥768px): horizontal — darker-left over copy, lighter-right over subject */
  @media (min-width: 768px) {
    .hero-overlay {
      background: linear-gradient(
        to right,
        rgba(22, 17, 14, 0.55),
        rgba(22, 17, 14, 0.20)
      );
    }
  }
</style>
