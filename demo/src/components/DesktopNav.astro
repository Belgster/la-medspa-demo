---
import { CATEGORIES, treatmentsByCategory } from '../data/navigation';
import ButtonLink from './ui/ButtonLink.astro';

const JANE_URL = 'https://laseradvantage.janeapp.com/';

// Current-page highlighting. Only About is a real route today; Services/
// Specials are in-page or flyout triggers, B&A is outbound. Extend here if
// more routes land in Phase 3.
const pathname = Astro.url.pathname;
const isAbout = pathname === '/about' || pathname === '/about/';
---
<header class="la-nav sticky top-0 z-40">
  <div class="max-w-[1400px] mx-auto flex items-center justify-between gap-stack px-card py-[20px]">
    <a
      href="/"
      class="la-nav-logo font-display font-medium text-[20px] tracking-[0.24em] uppercase no-underline whitespace-nowrap"
      aria-label="LA Medspa — home"
    >
      LA Medspa
    </a>

    <nav aria-label="Primary" class="flex gap-stack">
      {/* Services — mega-menu parent, not a link */}
      <button
        type="button"
        data-services-trigger
        aria-haspopup="true"
        aria-expanded="false"
        aria-controls="services-flyout"
        class:list={[
          'la-nav-item font-display font-medium text-[12px] uppercase tracking-[0.14em]',
          'py-[6px] border-b border-transparent bg-transparent cursor-pointer',
          'hover:border-gold focus-visible:border-gold',
          'inline-flex items-center gap-[4px] relative',
        ]}
      >
        Services <span aria-hidden="true">▾</span>
      </button>
      {/* Before & After — outbound to WordPress until Phase 3 brings it in-house */}
      <a
        href="https://ssmlaseradvantage.com/before-after/"
        target="_blank"
        rel="noopener noreferrer"
        class:list={[
          'la-nav-item font-display font-medium text-[12px] uppercase tracking-[0.14em]',
          'py-[6px] border-b border-transparent no-underline',
          'hover:border-gold focus-visible:border-gold',
          'inline-flex items-center gap-[4px]',
        ]}
      >
        Before &amp; After <span aria-hidden="true">↗</span>
      </a>
      {/* Specials — in-page anchor to FeaturedSpecial section */}
      <a
        href="#specials"
        class:list={[
          'la-nav-item font-display font-medium text-[12px] uppercase tracking-[0.14em]',
          'py-[6px] border-b border-transparent no-underline',
          'hover:border-gold focus-visible:border-gold',
        ]}
      >
        Specials
      </a>
      {/* About — /about route; active when pathname matches */}
      <a
        href="/about"
        aria-current={isAbout ? 'page' : undefined}
        class:list={[
          'la-nav-item font-display font-medium text-[12px] uppercase tracking-[0.14em]',
          'py-[6px] border-b no-underline',
          'hover:border-gold focus-visible:border-gold',
          isAbout ? 'text-ink border-gold' : 'border-transparent',
        ]}
      >
        About
      </a>
    </nav>

    <ButtonLink href={JANE_URL} external variant="primary">
      Book Consultation
    </ButtonLink>
  </div>

  {/* Services mega-menu — single flyout, all six categories */}
  <div
    id="services-flyout"
    data-services-flyout
    role="region"
    aria-label="All services"
    class:list={[
      'la-flyout',
      'absolute left-0 right-0 top-full',
      'bg-cream border-b border-hairline shadow-md',
    ]}
  >
    <div class="max-w-[1400px] mx-auto px-card py-card">
      <div class="font-mono text-[10.5px] uppercase tracking-[0.14em] text-charcoal-soft mb-card">
        Services
      </div>
      <div class="grid grid-cols-3 min-[1200px]:grid-cols-6 gap-stack">
        {CATEGORIES.map((c) => (
          <div class="flex flex-col">
            <div class="font-display font-medium text-[16px] uppercase text-ink mb-[14px]">
              {c.label}
            </div>
            <ul class="space-y-[8px] mb-[16px] flex-1">
              {(treatmentsByCategory[c.key] ?? []).slice(0, 4).map((t) => (
                <li>
                  <a
                    href={t.href}
                    class="block font-body font-light text-[13px] leading-[1.4] text-brown no-underline hover:text-gold focus-visible:text-gold focus-visible:outline-none transition-colors duration-la-base ease-la-ease"
                  >
                    {t.name}
                  </a>
                </li>
              ))}
            </ul>
            <a
              href={`#category-${c.key}`}
              class="inline-flex items-center gap-[4px] font-display font-medium text-[10.5px] uppercase tracking-[0.14em] text-gold no-underline hover:text-gold-hover focus-visible:text-gold-hover focus-visible:outline-none transition-colors duration-la-base ease-la-ease"
            >
              <span aria-hidden="true">+</span> See all {c.label.toLowerCase()}
            </a>
          </div>
        ))}
      </div>
    </div>
  </div>
</header>

<style is:global>
  /*
   * DesktopNav mega-menu — single SERVICES flyout. Visuals driven by
   * :has() + :focus-within; small inline script (below) mirrors open/
   * closed state to aria-expanded so screen readers stay in sync.
   */
  .la-flyout {
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    pointer-events: none;
    transition:
      opacity 400ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 400ms cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0s linear 400ms;
  }

  /*
   * Hover bridge — pseudo-element extends the trigger's hover target down
   * to the flyout's top edge so the cursor never leaves during transit.
   */
  [data-services-trigger]::after {
    content: '';
    position: absolute;
    left: -12px;
    right: -12px;
    top: 100%;
    height: 32px;
  }

  header:has([data-services-trigger]:hover) [data-services-flyout],
  header:has([data-services-trigger]:focus-visible) [data-services-flyout],
  header [data-services-flyout]:hover,
  header [data-services-flyout]:focus-within {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
    transition-delay: 0s;
  }
</style>

<script>
  // Mirror the flyout's visible state to aria-expanded; wire Escape-to-close.
  // Keyboard navigation inside the flyout is handled by native Tab order
  // through the focusable <a> elements — no custom arrow-key handling here.
  const trigger = document.querySelector<HTMLButtonElement>('[data-services-trigger]');
  const flyout = document.querySelector<HTMLElement>('[data-services-flyout]');
  if (trigger && flyout) {
    const sync = () => {
      const isOpen =
        trigger.matches(':hover') ||
        flyout.matches(':hover') ||
        document.activeElement === trigger ||
        flyout.contains(document.activeElement);
      trigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    };
    trigger.addEventListener('mouseenter', sync);
    trigger.addEventListener('mouseleave', sync);
    flyout.addEventListener('mouseenter', sync);
    flyout.addEventListener('mouseleave', sync);
    document.addEventListener('focusin', sync);
    document.addEventListener('focusout', () => setTimeout(sync, 0));
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      const active = document.activeElement as HTMLElement | null;
      if (active && (active === trigger || flyout.contains(active))) {
        active.blur();
        setTimeout(sync, 0);
      }
    });
  }
</script>
