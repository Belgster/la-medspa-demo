---
import DesktopNav from './DesktopNav.astro';
import { MobileNav } from './ui/Navigation';
import { treatmentsByCategory } from '../data/navigation';

const JANE_URL = 'https://laseradvantage.janeapp.com/';
const SHOP_URL = 'https://laseradvantage.myshopify.com/';
---
<!--
  display: contents so the sticky <header> inside each nav becomes a direct
  child of <body> for layout purposes. Without this the wrapper box is only
  ~72px tall and sticky releases on the first px of scroll.
-->
<div class="hidden md:contents">
  <DesktopNav />
</div>
<div class="contents md:hidden">
  <MobileNav
    client:visible
    treatmentsByCategory={treatmentsByCategory}
    bookHref={JANE_URL}
    shopHref={SHOP_URL}
  />
</div>
