---
/*
 * §6 — Before & After · Real Results
 *
 * Mirrors the two lip-filler pairs already public on
 * ssmlaseradvantage.com. Source PNGs (500×500) were downloaded once
 * and committed to the repo; astro:assets emits AVIF + WebP at build.
 *
 * The drag-comparison slider is a zero-dependency React island
 * (BeforeAfterPair.tsx) — vanilla pointer events + clip-path.
 * client:visible hydration: no runtime cost until the section scrolls
 * into view.
 */
import { getImage } from 'astro:assets';
import { BeforeAfterPair } from './ui/BeforeAfterPair';

import pair1Before from '../assets/before-after/lip-filler-1-before.png';
import pair1After  from '../assets/before-after/lip-filler-1-after.png';
import pair2Before from '../assets/before-after/lip-filler-2-before.png';
import pair2After  from '../assets/before-after/lip-filler-2-after.png';

// Source PNGs are 500×500; emit AVIF + WebP at native resolution.
// Browser will upscale to the ~560-700px display size; retina loss is
// unavoidable without higher-res source. No duplicate srcset entries.
const p = async (src: ImageMetadata, format: 'avif' | 'webp') =>
  (await getImage({ src, format, width: 500 })).src;

const [p1bA, p1bW, p1aA, p1aW, p2bA, p2bW, p2aA, p2aW] = await Promise.all([
  p(pair1Before, 'avif'), p(pair1Before, 'webp'),
  p(pair1After,  'avif'), p(pair1After,  'webp'),
  p(pair2Before, 'avif'), p(pair2Before, 'webp'),
  p(pair2After,  'avif'), p(pair2After,  'webp'),
]);
---
<section id="results" class="max-w-[1400px] mx-auto px-card py-[56px] md:py-section-s lg:py-section-l">
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-comfort mb-stack">
    <div class="max-w-[560px]">
      <div class="font-display font-medium text-[11px] uppercase tracking-[0.14em] text-charcoal-soft mb-comfort">
        Before & After · Real Results
      </div>
      <h2 class="font-display font-medium uppercase text-ink text-[clamp(32px,4.5vw,48px)] tracking-[-0.01em] leading-[1.05]">
        Real Client<br />Results
      </h2>
    </div>
    <p class="max-w-[420px] font-body font-light text-[15px] leading-[1.7] text-charcoal">
      Two clients, one treatment. The gallery opens wider in Phase 3 —
      for now, see what lip filler actually looks like done by our team.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-stack">
    <BeforeAfterPair
      client:visible
      beforeAvif={p1bA}
      beforeWebp={p1bW}
      afterAvif={p1aA}
      afterWebp={p1aW}
      alt="Lip filler client 1"
      caption="Lip Filler · LA Medspa"
    />
    <BeforeAfterPair
      client:visible
      beforeAvif={p2bA}
      beforeWebp={p2bW}
      afterAvif={p2aA}
      afterWebp={p2aW}
      alt="Lip filler client 2"
      caption="Lip Filler · LA Medspa"
    />
  </div>

  <div class="mt-stack text-center">
    <a
      href="#phase3-ba"
      class="font-display font-medium text-[12px] uppercase tracking-[0.18em] text-brown no-underline inline-flex items-center gap-[8px] border-b border-transparent hover:border-brown focus-visible:border-brown transition-colors duration-la-base ease-la-ease"
    >
      View all results <span aria-hidden="true">→</span>
    </a>
  </div>
</section>
