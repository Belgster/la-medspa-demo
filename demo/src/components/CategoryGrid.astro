---
/*
 * §3 — Six service categories.
 *
 * Each card has an editorial image band up top, sourced from the existing
 * asset pack. Three categories (body/hair/wellness) are using proxies — see
 * TODO flags on those imports for Phase 3 capture work.
 */
import type { ImageMetadata } from 'astro';
import { Picture } from 'astro:assets';

// Face — injectables / facial close-up
import faceImg     from '../assets/40.jpg';
// Body — TODO Phase 3: needs body-specific shot (currently skin-focused proxy)
import bodyImg     from '../assets/157.jpg';
// Hair — TODO Phase 3: needs hair treatment shot (currently atmospheric proxy)
import hairImg     from '../assets/332.jpg';
// Medical — clinical equipment / prescriber atmosphere
import medicalImg  from '../assets/80.jpg';
// Wellness — TODO Phase 3: needs IV / vitamin / hormone shot (currently consultation proxy)
import wellnessImg from '../assets/90.jpg';
// Skin Care — medical-grade skin close-up
import skincareImg from '../assets/70.jpg';

type CategoryKey = 'face' | 'body' | 'hair' | 'medical' | 'wellness' | 'skincare';

const IMAGES: Record<CategoryKey, ImageMetadata> = {
  face:     faceImg,
  body:     bodyImg,
  hair:     hairImg,
  medical:  medicalImg,
  wellness: wellnessImg,
  skincare: skincareImg,
};

interface CategoryCard {
  key: CategoryKey;
  label: string;
  index: string;
  /** Strings are non-interactive pills. Objects with `href` render as outbound
   *  links with an ↗ glyph — used for the Skin Care → Shopify touchpoint. */
  marquee: Array<string | { name: string; href: string }>;
  blurb: string;
}

const SHOP_URL = 'https://laseradvantage.myshopify.com/';

const CATEGORIES: CategoryCard[] = [
  {
    key: 'face',
    label: 'Face',
    index: '01',
    marquee: ['Botox', 'Fillers', 'HydraFacial', 'Bela MD', 'Microneedling'],
    blurb:
      'Injectables, editorial facials, and laser resurfacing. The range of non-surgical rejuvenation delivered by prescribers.',
  },
  {
    key: 'body',
    label: 'Body',
    index: '02',
    marquee: ['CoolSculpting', 'TightSculpting', 'TightWave', 'Laser Hair Removal'],
    blurb:
      'Contouring, tightening, and body-wide treatments — from fat reduction to tattoo removal and vein therapy.',
  },
  {
    key: 'hair',
    label: 'Hair',
    index: '03',
    marquee: ['PRP', 'Keravive', 'HAIRestart', 'Mesotherapy'],
    blurb:
      'Follicle-level restoration using the plasma, laser, and nutrient therapies with evidence behind them.',
  },
  {
    key: 'medical',
    label: 'Medical',
    index: '04',
    marquee: ['Hormone Therapy', 'Botox · Migraines', 'NightLase', 'Sclerotherapy'],
    blurb:
      'Prescriber-led treatments with clinical indication. Hormone therapy, neurological Botox, vein medicine, and sleep therapy.',
  },
  {
    key: 'wellness',
    label: 'Wellness',
    index: '05',
    marquee: ['IV Therapy', 'Vitamin Injections', 'Hormone Therapy'],
    blurb:
      'IV drips, vitamin injections, hormone support, and sleep therapies. Medicine that works from the inside out.',
  },
  {
    key: 'skincare',
    label: 'Skin Care',
    index: '06',
    marquee: [
      'Bela MD',
      'Skin Booster',
      'Chemical Peel',
      'SmoothEye',
      { name: 'Medical-Grade Products', href: SHOP_URL },
    ],
    blurb:
      'Medical-grade facials and products that extend what clinic visits start — carried between appointments.',
  },
];
---
<section id="services" class="max-w-[1400px] mx-auto px-card py-section-s lg:py-section-l">
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-comfort mb-stack">
    <div class="max-w-[620px]">
      <div class="font-display font-medium text-[11px] uppercase tracking-[0.14em] text-charcoal-soft mb-comfort">
        Six categories · one standard
      </div>
      <h2 class="font-display font-medium uppercase text-ink text-[clamp(32px,4.5vw,48px)] tracking-[-0.01em] leading-[1.05]">
        What We Do
      </h2>
    </div>
    <p class="max-w-[420px] font-body font-light text-[15px] leading-[1.7] text-charcoal">
      From injectables to hormone therapy, every category sits under one
      prescriber-led roof.
    </p>
  </div>

  <div class="grid grid-cols-2 lg:grid-cols-3 gap-[12px] lg:gap-comfort">
    {CATEGORIES.map((c) => (
      <article
        class="group relative flex flex-col bg-cream border border-hairline rounded-card overflow-hidden transition-all duration-la-base ease-la-ease hover:border-[#D4C8B8] hover:shadow-md focus-within:border-[#D4C8B8] focus-within:shadow-md"
      >
        <div class="image-band aspect-[4/3] md:aspect-[16/10] overflow-hidden">
          <Picture
            src={IMAGES[c.key]}
            formats={['webp']}
            widths={[320, 480, 640, 800]}
            sizes="(min-width: 1024px) 30vw, (min-width: 640px) 45vw, 90vw"
            alt=""
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover transition-transform duration-700 ease-la-ease group-hover:scale-[1.03]"
          />
        </div>
        <div class="p-[20px] md:p-card flex flex-col flex-1">
          <div class="flex items-start justify-between mb-comfort">
            <div class="font-display font-medium text-[44px] leading-none text-gold">
              {c.index}
            </div>
            <div class="font-mono text-[10.5px] uppercase tracking-[0.14em] text-charcoal-soft pt-[6px]">
              {c.marquee.length}+ treatments
            </div>
          </div>
          <div class="font-display font-medium uppercase text-ink text-[20px] md:text-[26px] leading-[1.1] mb-[12px]">
            {c.label}
          </div>
          <p class="hidden md:block font-body font-light text-[14px] leading-[1.7] text-charcoal mb-card">
            {c.blurb}
          </p>
          <div class="flex flex-wrap gap-[6px] mb-stack">
            {c.marquee.map((m) => {
              const isLink = typeof m !== 'string';
              const label = isLink ? m.name : m;
              const base = 'font-display font-medium text-[10px] uppercase tracking-[0.12em] px-[10px] py-[4px] rounded-pill inline-flex items-center gap-[4px]';
              if (isLink) {
                return (
                  <a
                    href={m.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class:list={[
                      base,
                      'bg-beige text-brown',
                      'no-underline transition-all duration-la-base ease-la-ease hover:brightness-95 focus-visible:brightness-95 focus-visible:outline-none focus-visible:shadow-focus',
                    ]}
                  >
                    {label}
                    <span aria-hidden="true">↗</span>
                  </a>
                );
              }
              return (
                <span class:list={[base, 'bg-beige text-brown']}>
                  {label}
                </span>
              );
            })}
          </div>
          <a
            href={`#category-${c.key}`}
            class:list={[
              'mt-auto font-display font-medium text-[11px] uppercase tracking-[0.14em] no-underline flex items-center gap-[8px] w-fit',
              'focus-visible:outline-none focus-visible:shadow-focus rounded-[4px]',
              'text-gold',
            ]}
          >
            <span>Explore {c.label.toLowerCase()}</span>
            <span aria-hidden="true" class="transition-transform duration-la-base ease-la-ease group-hover:translate-x-[4px]">→</span>
          </a>
        </div>
      </article>
    ))}
  </div>
</section>
