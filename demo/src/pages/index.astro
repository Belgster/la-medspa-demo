---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import LeaderIntro from '../components/LeaderIntro.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import HormoneSpotlight from '../components/HormoneSpotlight.astro';
import ConcernFinderSection from '../components/ConcernFinderSection.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import Testimonials from '../components/Testimonials.astro';
import FinancingInstagram from '../components/FinancingInstagram.astro';
import heroDesktop from '../assets/hero-desktop.jpg';
import heroMobile from '../assets/hero-mobile.jpg';
---
<Layout preloadImage={heroDesktop} preloadImageMobile={heroMobile}>
  <Hero />
  <LeaderIntro />
  <CategoryGrid />
  <HormoneSpotlight />
  <ConcernFinderSection />
  <BeforeAfter />
  <Testimonials />
  <FinancingInstagram />
</Layout>
