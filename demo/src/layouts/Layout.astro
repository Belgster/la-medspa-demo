---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title?: string;
  description?: string;
  /** If set, pre-computes AVIF/WebP URLs and emits <link rel="preload"> hints for LCP. */
  preloadImage?: ImageMetadata;
}

const {
  title = 'LA Medspa — Medical Aesthetics in Sault Ste. Marie',
  description = 'Medical-grade expertise delivered with the warmth of a high-end spa. Less is more. Simple is best. Always natural.',
  preloadImage,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

let preloadAvif: string | null = null;
let preloadWebp: string | null = null;
if (preloadImage) {
  const avifWidths = await Promise.all(
    [960, 1280, 1600, 2000, 2400].map((w) => getImage({ src: preloadImage, format: 'avif', width: w })),
  );
  const webpWidths = await Promise.all(
    [960, 1280, 1600, 2000, 2400].map((w) => getImage({ src: preloadImage, format: 'webp', width: w })),
  );
  preloadAvif = avifWidths.map((i, idx) => `${i.src} ${[960, 1280, 1600, 2000, 2400][idx]}w`).join(', ');
  preloadWebp = webpWidths.map((i, idx) => `${i.src} ${[960, 1280, 1600, 2000, 2400][idx]}w`).join(', ');
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <meta name="theme-color" content="#FEFDF7" />

    {preloadAvif && (
      <link
        rel="preload"
        as="image"
        imagesrcset={preloadAvif}
        imagesizes="100vw"
        type="image/avif"
        fetchpriority="high"
      />
    )}
    {preloadWebp && (
      <link
        rel="preload"
        as="image"
        imagesrcset={preloadWebp}
        imagesizes="100vw"
        type="image/webp"
        fetchpriority="high"
      />
    )}

    <slot name="head" />
  </head>
  <body class="min-h-screen bg-cream text-charcoal font-body antialiased">
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
